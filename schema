/* shared/schema.ts
 *
 * SafeFlow integration contract for:
 * - Map / zones / graph
 * - ML perception output
 * - Risk fusion output
 * - Routing output
 * - Incidents + assist workflow
 * - WebSocket event stream
 *
 * Conventions:
 * - All coordinates are in the SAME coordinate space as the rendered map (e.g., SVG pixels).
 * - Zone membership can be polygon-based; routing edges reference zoneId directly.
 * - Location for users/incidents can be zone-level OR x/y (optional).
 * - Timestamps are epoch milliseconds (Date.now()).
 */

//////////////////////////////
// Common / Utility Types
//////////////////////////////

export type EpochMs = number;
export type ID = string;

export type Coord2D = {
  x: number;
  y: number;
};

/ Optional confidence value 0..1 */
export type Confidence = number;

/ Severity scale (keep simple for hackathon) */
export type Severity = "info" | "warn" | "critical";

/ Actor role determines which alerts they can receive */
export type UserRole = "user" | "staff" | "ally" | "admin";

/ For indoor demo: zone-level location is acceptable */
export type ZoneLocation = {
  zoneId: ID;
  / optional precise position if available */
  pos?: Coord2D;
};

//////////////////////////////
// Map / Zones / Graph
//////////////////////////////

/ Zones define areas where risk is aggregated and displayed */
export type Zone = {
  id: ID; // e.g., "Z1"
  name: string; // e.g., "Food Court"
  / Polygon in map coordinate space (SVG pixels). Minimum 3 points. */
  polygon: Coord2D[];
  / Optional: recommended safe points in this zone (like staff desk) */
  safePoints?: Coord2D[];
};

/ Node in navigation graph (junction, door, escalator entry, etc.) */
export type GraphNode = {
  id: ID; // e.g., "N12"
  pos: Coord2D;
  / Optional label (Exit A, Stair 2, etc.) */
  label?: string;
  / Optional type */
  kind?: "junction" | "exit" | "stairs" | "elevator" | "poi";
};

/ Edge in navigation graph (corridor segment) */
export type GraphEdge = {
  id: ID; // e.g., "E33"
  from: ID; // nodeId
  to: ID; // nodeId
  / Physical length in map units (or meters if you calibrate). */
  length: number;
  / Which zone this edge belongs to (used to apply zone risk penalties). */
  zoneId: ID;
  / Optional: corridor capacity meta */
  meta?: {
    width?: number; // meters or relative
    isAccessible?: boolean;
    isOneWay?: boolean;
  };
};

/ Full map package */
export type MapData = {
  mapId: ID; // e.g., "mall_demo_v1"
  / Used by frontend for background rendering (optional) */
  mapImageUrl?: string; // could be served by frontend/static
  zones: Zone[];
  graph: {
    nodes: GraphNode[];
    edges: GraphEdge[];
  };
  / Exits for convenience */
  exits: ID[]; // list of nodeIds that are exits
};

//////////////////////////////
// ML Perception Contracts
//////////////////////////////

/
 * ML Perception returns per-zone signals derived from video frames.
 * NOTE: Keep this output simple. The backend does fusion/routing.
 */
export type ZonePerception = {
  zoneId: ID;
  / Density score: 0..1, where 1 is "very crowded" */
  density: number;
  / Motion anomaly score: 0..1, where 1 is "highly abnormal / panic-like" */
  anomaly: number;
  / Optional metadata */
  conf?: Confidence;
  / Optional raw counts from detector */
  peopleCount?: number;
};

/ ML inference output for a single frame/batch */
export type PerceptionFrameResult = {
  ts: EpochMs;
  frameId?: ID; // optional if you track frames
  zones: ZonePerception[];
};
/ REST: ML service endpoint signature (suggested) */
export type MlInferFrameResponse = PerceptionFrameResult;

/ REST: backend may call ML service with a frame reference; use what’s easiest */
export type MlInferFrameRequest =
  | {
      // Option A: send a frame image (base64) - not always needed for hackathon
      kind: "image_base64";
      ts: EpochMs;
      imageBase64: string; // "data:image/jpeg;base64,..."
    }
  | {
      // Option B: send a video source + frame index (ML service loads video)
      kind: "video_ref";
      ts: EpochMs;
      videoId: ID; // e.g., "normal_1", "crowded_2"
      frameIndex: number;
    };

//////////////////////////////
// Risk Fusion Output (Backend truth)
//////////////////////////////

/ Backend’s fused view of each zone */
export type ZoneRisk = {
  zoneId: ID;
  / Final fused risk: 0..1 */
  risk: number;
  / Echo sources to support explainability in UI */
  density?: number;
  anomaly?: number;
  / Optional trend component (e.g., rising risk) */
  trend?: number;
  / Severity bucket for UI + alert thresholds */
  severity: Severity;
  / Optional confidence */
  conf?: Confidence;
};

/ Entire risk map payload */
export type RiskMap = {
  ts: EpochMs;
  mapId: ID;
  zones: ZoneRisk[];
};

//////////////////////////////
// Users & Routing
//////////////////////////////

/ Minimal user state (demo-friendly) */
export type UserState = {
  userId: ID;
  role: UserRole;
  / Zone-level indoor location is sufficient */
  loc: ZoneLocation;
  / Optional destination: an exit node or a POI node */
  destinationNodeId?: ID;
  / Optional group id for "guardian mode" groups */
  groupId?: ID;
  / Women-safety features toggles */
  safety?: {
    guardianMode?: boolean;
    silentMode?: boolean; // prefer discreet notifications
    trustedContacts?: ID[]; // in-demo ids
  };
};

/ Route computed by backend */
export type RoutePlan = {
  userId: ID;
  ts: EpochMs;
  mapId: ID;
  / Node path for rendering */
  pathNodeIds: ID[];
  / Optional: edge path */
  pathEdgeIds?: ID[];
  / Why the route updated */
  reason:
    | "initial"
    | "risk_reroute"
    | "hazard_reroute"
    | "destination_changed"
    | "manual_request";
  / Optional: which zones were avoided */
  avoidedZoneIds?: ID[];
  / Optional: estimated distance/time */
  est?: {
    distance: number;
    timeSec?: number;
  };
};

/ Backend route request (if frontend asks explicitly) */
export type RouteRequest = {
  userId: ID;
  mapId: ID;
  fromNodeId?: ID; // optional if backend maps user loc->nearest node
  toNodeId: ID; // destination nodeId (exit or poi)
  preferAccessible?: boolean;
};

//////////////////////////////
// Incidents & Assist Workflow
//////////////////////////////

export type IncidentType =
  | "overcrowding"
  | "panic_motion"
  | "blocked_corridor"
  | "fall_detected"
  | "distress_triggered"
  | "harassment_report";

export type Incident = {
  incidentId: ID;
  ts: EpochMs;
  mapId: ID;
  type: IncidentType;
  severity: Severity;

  / Where the incident is (zone-level required, pos optional) */
  loc: ZoneLocation;

  / Optional description for staff dashboard */
  description?: string;

  / Optional: link incident to a reporting user */
  reporterUserId?: ID;

  / How certain the system is (0..1) */
  conf?: Confidence;

  / Optional: affects routing by penalizing nearby edges */
  routingImpact?: {
    / meters or map-units radius around loc.pos; if pos missing, interpret as zone-wide */
    radius?: number;
    / penalty added to edges within impact (tune in backend) */
    hazardPenalty?: number;
    / if true, edges may be treated as blocked */
    isBlocking?: boolean;
  };

  / Lifecycle for staff handling */
  status?: "open" | "acknowledged" | "resolved";
  acknowledgedBy?: ID; // staff/ally userId
  resolvedBy?: ID; // staff/ally userId
};
/ Assist request sent to staff/allies */
export type AssistRequest = {
  requestId: ID;
  ts: EpochMs;
  mapId: ID;
  incidentId: ID;
  / Who should receive it (role-based + proximity filtering happens in backend) */
  targetRole: "staff" | "ally";
  / Provide enough info to act without revealing sensitive details */
  loc: ZoneLocation;
  severity: Severity;
  message: string;
  / Optional: for sorting */
  distanceEstimate?: number; // map units or meters
  / Whether accepting assigns responder and stops further alerts */
  exclusive?: boolean;
};

/ Response from staff/ally */
export type AssistResponse = {
  requestId: ID;
  ts: EpochMs;
  responderUserId: ID;
  action: "accept" | "decline";
};

//////////////////////////////
// Women-Safety Signals
//////////////////////////////

export type SafetySignalType =
  | "silent_trigger"
  | "coded_text_trigger"
  | "guardian_no_response"
  | "manual_help_request";

export type SafetySignal = {
  signalId: ID;
  ts: EpochMs;
  userId: ID;
  mapId: ID;
  type: SafetySignalType;
  loc: ZoneLocation;
  / Optional note shown only to staff */
  note?: string;
  / Optional confidence */
  conf?: Confidence;
};

//////////////////////////////
// WebSocket Events
//////////////////////////////

/ All server -> client events share this envelope */
export type WsServerEvent =
  | {
      type: "risk_update";
      payload: RiskMap;
    }
  | {
      type: "incident";
      payload: Incident;
    }
  | {
      type: "route_update";
      payload: RoutePlan;
    }
  | {
      type: "assist_request";
      payload: AssistRequest;
    }
  | {
      type: "user_update";
      payload: UserState;
    }
  | {
      type: "system_status";
      payload: {
        ts: EpochMs;
        mlMode: "fake" | "real";
        fps?: number;
        note?: string;
      };
    };

/ Client -> server WS messages */
export type WsClientEvent =
  | {
      type: "route_request";
      payload: RouteRequest;
    }
  | {
      type: "assist_response";
      payload: AssistResponse;
    }
  | {
      type: "safety_signal";
      payload: SafetySignal;
    }
  | {
      type: "user_presence";
      payload: {
        userId: ID;
        ts: EpochMs;
        /** Update location (zone-level) */
        loc: ZoneLocation;
      };
    };

